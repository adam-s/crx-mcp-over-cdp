{
  "extends": "@crx-mcp-over-cdp/tsconfig/esnext.json",
  "compilerOptions": {
    "allowJs": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "vs/*": [
        "vs/*"
      ],
    },
    "types": [
      "chrome",
      "vitest/globals"
    ],
  },
  "include": [
    "index.ts",
    "vs",
    "**.*.ts"
  ],
  "exclude": [
    "vs/**/test/**",
    "vs/**/tests/**",
    "vs/base/test/**",
    "vs/base/common/marked/**"
  ]
}